PORT=5000

# MongoDB Atlas — get this from Atlas → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fintechel?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<db_user>:<password>@<cluster>.mongodb.net/fintechel?retryWrites=true&w=majority&appName=Cluster0

JWT_SECRET=change-this-to-a-long-random-secret-in-production
NODE_ENV=development
